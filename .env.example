# DATABASE CONFIGURATION
# For Render: Use PostgreSQL (e.g., from Render, Neon, Railway, Supabase)
DB_URL=jdbc:postgresql://your-host:5432/your-database?sslmode=require
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_DRIVER=org.postgresql.Driver

# For Local Development (MySQL):
# DB_URL=jdbc:mysql://localhost:3306/todo?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_DRIVER=com.mysql.cj.jdbc.Driver

# EMAIL CONFIGURATION (Gmail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# GOOGLE OAUTH (Optional)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_FONTS_API_KEY=your-api-key

# PORT (Set by Render, default 8080)
PORT=8080
